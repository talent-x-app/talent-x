{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Talent-X Design System — source of truth. W3C Design Tokens format. Light & dark themes derive their semantic values from the primitive ramps below.",

  "color": {
    "$type": "color",
    "primitive": {
      "blue": {
        "50":  { "$value": "#EBF3FF" },
        "100": { "$value": "#D6E7FF" },
        "200": { "$value": "#ADCFFF" },
        "300": { "$value": "#85B8FF" },
        "400": { "$value": "#5BAEFF", "$description": "Blue light — top of the X gradient / highlight" },
        "500": { "$value": "#2E7CF6", "$description": "Blue — PRIMARY accent, the X" },
        "600": { "$value": "#1B5BE0", "$description": "Blue deep — bottom of the X gradient / pressed" },
        "700": { "$value": "#1747B0" },
        "800": { "$value": "#143A8C" },
        "900": { "$value": "#102C66" }
      },
      "navy": { "$value": "#1F4E79", "$description": "Deep desaturated blue — wordmark & accent text on light backgrounds" },
      "slate": {
        "0":   { "$value": "#FFFFFF" },
        "50":  { "$value": "#F4F6FA" },
        "100": { "$value": "#E7ECF3", "$description": "Primary text on dark" },
        "200": { "$value": "#D3DAE6" },
        "300": { "$value": "#B6C0D0" },
        "400": { "$value": "#8A94A6", "$description": "Secondary / muted text on dark" },
        "500": { "$value": "#5C6678", "$description": "Faint text on dark" },
        "600": { "$value": "#434B5C" },
        "700": { "$value": "#2A3140" },
        "800": { "$value": "#161B27", "$description": "Raised surface (dark)" },
        "850": { "$value": "#11151F", "$description": "Surface (dark)" },
        "900": { "$value": "#0E121B", "$description": "Sunken surface (dark)" },
        "950": { "$value": "#0B0F17", "$description": "Ink — primary dark background" }
      },
      "success": {
        "50":  { "$value": "#E6F8EF" },
        "400": { "$value": "#34D17F" },
        "500": { "$value": "#1FA968" },
        "600": { "$value": "#178A55" }
      },
      "warning": {
        "50":  { "$value": "#FFF6E5" },
        "400": { "$value": "#FFC24B" },
        "500": { "$value": "#F5A524" },
        "600": { "$value": "#C9821A" }
      },
      "danger": {
        "50":  { "$value": "#FDECEE" },
        "400": { "$value": "#FF6B7A" },
        "500": { "$value": "#E5484D" },
        "600": { "$value": "#C23438" }
      },
      "info": {
        "50":  { "$value": "#EBF3FF" },
        "400": { "$value": "#5BAEFF" },
        "500": { "$value": "#2E7CF6" },
        "600": { "$value": "#1B5BE0" }
      },
      "white": { "$value": "#FFFFFF" },
      "black": { "$value": "#000000" }
    },

    "gradient": {
      "x": {
        "$type": "gradient",
        "$value": [
          { "color": "#5BAEFF", "position": 0 },
          { "color": "#2E7CF6", "position": 0.55 },
          { "color": "#1B5BE0", "position": 1 }
        ],
        "$description": "Signature 135° X gradient. Reserved for the brand mark / a single hero accent. Never on running text or as a fill behind UI."
      }
    },

    "theme": {
      "light": {
        "background":      { "$value": "{color.primitive.slate.50}" },
        "surface":         { "$value": "{color.primitive.white}" },
        "surface-raised":  { "$value": "{color.primitive.white}" },
        "surface-sunken":  { "$value": "#ECF0F6" },
        "border":          { "$value": "rgba(11,15,23,0.10)" },
        "border-strong":   { "$value": "rgba(11,15,23,0.18)" },
        "text-primary":    { "$value": "{color.primitive.slate.950}", "$description": "≥ 16:1 on surface — AAA" },
        "text-secondary":  { "$value": "#3C4456", "$description": "≈ 9:1 on white — AAA" },
        "text-muted":      { "$value": "{color.primitive.slate.500}", "$description": "≈ 5.2:1 on white — AA" },
        "text-on-accent":  { "$value": "{color.primitive.white}" },
        "accent":          { "$value": "{color.primitive.blue.500}" },
        "accent-hover":    { "$value": "{color.primitive.blue.600}" },
        "accent-pressed":  { "$value": "{color.primitive.blue.700}" },
        "accent-text":     { "$value": "{color.primitive.blue.700}", "$description": "Accent used as text/link on light — ≈ 6.4:1 AA" },
        "accent-subtle":   { "$value": "{color.primitive.blue.50}" },
        "focus-ring":      { "$value": "{color.primitive.blue.500}" },
        "overlay":         { "$value": "rgba(11,15,23,0.45)" },
        "success":         { "$value": "{color.primitive.success.600}" },
        "warning":         { "$value": "{color.primitive.warning.600}" },
        "danger":          { "$value": "{color.primitive.danger.500}" },
        "info":            { "$value": "{color.primitive.info.600}" }
      },
      "dark": {
        "background":      { "$value": "{color.primitive.slate.950}" },
        "surface":         { "$value": "{color.primitive.slate.850}" },
        "surface-raised":  { "$value": "{color.primitive.slate.800}" },
        "surface-sunken":  { "$value": "{color.primitive.slate.900}" },
        "border":          { "$value": "rgba(255,255,255,0.08)" },
        "border-strong":   { "$value": "rgba(255,255,255,0.16)" },
        "text-primary":    { "$value": "{color.primitive.slate.100}", "$description": "≈ 15:1 on ink — AAA" },
        "text-secondary":  { "$value": "{color.primitive.slate.400}", "$description": "≈ 6.4:1 on ink — AA" },
        "text-muted":      { "$value": "{color.primitive.slate.500}", "$description": "≈ 3.6:1 on ink — AA large / non-essential" },
        "text-on-accent":  { "$value": "{color.primitive.white}" },
        "accent":          { "$value": "{color.primitive.blue.500}" },
        "accent-hover":    { "$value": "{color.primitive.blue.400}" },
        "accent-pressed":  { "$value": "{color.primitive.blue.600}" },
        "accent-text":     { "$value": "{color.primitive.blue.400}", "$description": "Accent used as text/link on dark — ≈ 7:1 AAA" },
        "accent-subtle":   { "$value": "rgba(46,124,246,0.16)" },
        "focus-ring":      { "$value": "{color.primitive.blue.400}" },
        "overlay":         { "$value": "rgba(7,10,16,0.66)" },
        "success":         { "$value": "{color.primitive.success.400}" },
        "warning":         { "$value": "{color.primitive.warning.400}" },
        "danger":          { "$value": "{color.primitive.danger.400}" },
        "info":            { "$value": "{color.primitive.info.400}" }
      }
    }
  },

  "font": {
    "family": {
      "$type": "fontFamily",
      "primary": { "$value": ["Poppins", "sans-serif"], "$description": "Poppins (SIL OFL). Titles + UI for full coherence with the wordmark." }
    },
    "weight": {
      "$type": "fontWeight",
      "regular":  { "$value": 400 },
      "medium":   { "$value": 500 },
      "semibold": { "$value": 600 },
      "bold":     { "$value": 700 }
    }
  },

  "typography": {
    "$type": "typography",
    "display":  { "$value": { "fontFamily": "{font.family.primary}", "fontSize": "44px", "lineHeight": "1.08", "fontWeight": 700, "letterSpacing": "-0.02em" } },
    "h1":       { "$value": { "fontFamily": "{font.family.primary}", "fontSize": "34px", "lineHeight": "1.14", "fontWeight": 700, "letterSpacing": "-0.02em" } },
    "h2":       { "$value": { "fontFamily": "{font.family.primary}", "fontSize": "28px", "lineHeight": "1.2",  "fontWeight": 600, "letterSpacing": "-0.01em" } },
    "h3":       { "$value": { "fontFamily": "{font.family.primary}", "fontSize": "22px", "lineHeight": "1.27", "fontWeight": 600, "letterSpacing": "-0.01em" } },
    "title":    { "$value": { "fontFamily": "{font.family.primary}", "fontSize": "18px", "lineHeight": "1.33", "fontWeight": 600, "letterSpacing": "0" } },
    "body-lg":  { "$value": { "fontFamily": "{font.family.primary}", "fontSize": "17px", "lineHeight": "1.5",  "fontWeight": 400, "letterSpacing": "0" } },
    "body":     { "$value": { "fontFamily": "{font.family.primary}", "fontSize": "15px", "lineHeight": "1.55", "fontWeight": 400, "letterSpacing": "0" } },
    "body-sm":  { "$value": { "fontFamily": "{font.family.primary}", "fontSize": "13px", "lineHeight": "1.5",  "fontWeight": 400, "letterSpacing": "0" } },
    "caption":  { "$value": { "fontFamily": "{font.family.primary}", "fontSize": "12px", "lineHeight": "1.4",  "fontWeight": 500, "letterSpacing": "0.01em" } },
    "overline": { "$value": { "fontFamily": "{font.family.primary}", "fontSize": "11px", "lineHeight": "1.3",  "fontWeight": 600, "letterSpacing": "0.22em", "textTransform": "uppercase" } }
  },

  "spacing": {
    "$type": "dimension",
    "0":  { "$value": "0px" },
    "1":  { "$value": "4px" },
    "2":  { "$value": "8px" },
    "3":  { "$value": "12px" },
    "4":  { "$value": "16px" },
    "5":  { "$value": "20px" },
    "6":  { "$value": "24px" },
    "8":  { "$value": "32px" },
    "10": { "$value": "40px" },
    "12": { "$value": "48px" },
    "16": { "$value": "64px" },
    "20": { "$value": "80px" },
    "24": { "$value": "96px" }
  },

  "radius": {
    "$type": "dimension",
    "xs":   { "$value": "6px" },
    "sm":   { "$value": "10px" },
    "md":   { "$value": "14px" },
    "lg":   { "$value": "20px" },
    "xl":   { "$value": "28px" },
    "pill": { "$value": "999px" },
    "icon-tile": { "$value": "22.5%", "$description": "Squircle-style corner for app-icon tiles (~22% of side)" }
  },

  "elevation": {
    "$type": "shadow",
    "light": {
      "sm": { "$value": { "offsetX": "0", "offsetY": "1px", "blur": "2px",  "spread": "0", "color": "rgba(11,15,23,0.08)" } },
      "md": { "$value": { "offsetX": "0", "offsetY": "4px", "blur": "12px", "spread": "0", "color": "rgba(11,15,23,0.10)" } },
      "lg": { "$value": { "offsetX": "0", "offsetY": "12px","blur": "32px", "spread": "0", "color": "rgba(11,15,23,0.14)" } }
    },
    "dark": {
      "sm": { "$value": { "offsetX": "0", "offsetY": "1px", "blur": "0",    "spread": "0", "color": "rgba(255,255,255,0.06)" }, "$description": "Dark elevation = subtle hairline border, not a drop shadow" },
      "md": { "$value": { "offsetX": "0", "offsetY": "8px", "blur": "24px", "spread": "0", "color": "rgba(0,0,0,0.45)" } },
      "glow": { "$value": { "offsetX": "0", "offsetY": "0", "blur": "24px", "spread": "0", "color": "rgba(46,124,246,0.35)" }, "$description": "Accent halo for focused/featured surfaces on dark" }
    }
  },

  "motion": {
    "duration": {
      "$type": "duration",
      "fast": { "$value": "120ms" },
      "base": { "$value": "220ms" },
      "slow": { "$value": "360ms" }
    },
    "easing": {
      "$type": "cubicBezier",
      "standard":   { "$value": [0.2, 0, 0, 1] },
      "decelerate": { "$value": [0, 0, 0.2, 1] },
      "accelerate": { "$value": [0.4, 0, 1, 1] },
      "spring":     { "$value": [0.34, 1.56, 0.64, 1], "$description": "Overshoot spring for press/pop affordances" }
    }
  },

  "opacity": {
    "disabled": { "$value": "0.4" },
    "muted":    { "$value": "0.64" },
    "hover-veil": { "$value": "0.08" }
  },

  "border-width": {
    "$type": "dimension",
    "hairline": { "$value": "1px" },
    "thick":    { "$value": "2px" },
    "focus":    { "$value": "2px" }
  },

  "z-index": {
    "base": { "$value": "0" },
    "sticky": { "$value": "100" },
    "appbar": { "$value": "200" },
    "tabbar": { "$value": "200" },
    "overlay": { "$value": "1000" },
    "modal": { "$value": "1100" },
    "toast": { "$value": "1200" }
  },

  "icon-size": {
    "$type": "dimension",
    "xs": { "$value": "16px" },
    "sm": { "$value": "20px" },
    "md": { "$value": "24px" },
    "lg": { "$value": "32px" }
  },

  "size": {
    "touch-target": { "$type": "dimension", "$value": "44px", "$description": "Minimum interactive target (iOS/Android/WCAG)" }
  },

  "breakpoint": {
    "$type": "dimension",
    "sm": { "$value": "480px" },
    "md": { "$value": "768px" },
    "lg": { "$value": "1024px" },
    "xl": { "$value": "1280px" }
  }
}
