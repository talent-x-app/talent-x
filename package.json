{
  "name": "talent-x",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "dev:api": "pnpm --filter @talent-x/api dev",
    "dev:mobile": "pnpm --filter @talent-x/mobile start"
  },
  "devDependencies": {
    "@talent-x/tsconfig": "workspace:*",
    "typescript": "~5.6.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma"
    ]
  }
}
