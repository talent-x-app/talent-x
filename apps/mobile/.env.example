# Configuration publique de l'app mobile (Expo).
# Les variables EXPO_PUBLIC_* sont injectées dans le bundle au build : n'y mettre
# QUE des valeurs publiques (jamais de secret). Copier en `.env` (non versionné).

# URL de base de l'API Talent-X, préfixe /api/v1 inclus.
EXPO_PUBLIC_API_URL=http://localhost:3000/api/v1
