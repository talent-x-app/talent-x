# Copier en `.env` (non versionné) et adapter.
# Valeurs ci-dessous = défauts du Docker Compose de dev (docker-compose.yml).
# Aucune valeur réelle de staging/prod ne doit figurer ici : ce sont des secrets
# d'environnement (cf. README « Environnements & secrets »).

# development | test | staging | production
NODE_ENV=development

# Port d'écoute de l'API (défaut 3000).
PORT=3000

# Base PostgreSQL locale (service `postgres` du docker-compose).
DATABASE_URL="postgresql://talentx:talentx@localhost:5432/talentx?schema=public"

# Redis local (service `redis` du docker-compose) — optionnel tant que le worker
# BullMQ n'est pas câblé. Décommenter quand nécessaire.
# REDIS_URL="redis://localhost:6379"
