# Copier en `.env` (non versionné) et adapter.
# Valeurs ci-dessous = défauts du Docker Compose de dev (docker-compose.yml).
# Aucune valeur réelle de staging/prod ne doit figurer ici : ce sont des secrets
# d'environnement (cf. README « Environnements & secrets »).

# development | test | staging | production
NODE_ENV=development

# Port d'écoute de l'API (défaut 3000).
PORT=3000

# Base PostgreSQL locale (service `postgres` du docker-compose).
DATABASE_URL="postgresql://talentx:talentx@localhost:5432/talentx?schema=public"

# Redis local (service `redis` du docker-compose) — file de jobs BullMQ (TLX-035).
# REQUIS pour le worker et en staging/production ; optionnel pour l'API seule en dev.
REDIS_URL="redis://localhost:6379"

# --- Stockage objet OVH (S3) — archives d'export RGPD (TLX-035 / ADR-13) ---
# REQUIS en staging/production et pour le worker. En staging/prod : OVH Object
# Storage + secrets d'environnement (jamais committés).
# S3_ENDPOINT="https://s3.gra.io.cloud.ovh.net"
# S3_REGION="gra"
# S3_BUCKET="talentx-exports"
# S3_ACCESS_KEY_ID="..."
# S3_SECRET_ACCESS_KEY="..."
#
# En DEV : MinIO local (service `minio` du docker-compose, bucket créé
# automatiquement). Identifiants dev NON secrets :
# S3_ENDPOINT="http://localhost:9000"
# S3_REGION="us-east-1"
# S3_BUCKET="talentx-exports"
# S3_ACCESS_KEY_ID="talentx"
# S3_SECRET_ACCESS_KEY="talentx-dev-secret"

# --- Export RGPD — durées (non secrètes, défauts sûrs) ---
# Durée de vie de l'archive avant purge (heures → expires_at). Défaut 24.
# EXPORT_ARCHIVE_TTL_HOURS=24
# TTL de l'URL présignée de téléchargement (secondes). Défaut 86400 (24 h).
# EXPORT_URL_TTL_SECONDS=86400

# --- Effacement RGPD (TLX-034 / ADR-15) — non secret ---
# Délai de rétention avant purge/anonymisation définitive d'un compte supprimé
# (jours). Défaut 30 (aligné sur la rétention des sauvegardes, TX-SEC-003 §9.2).
# ACCOUNT_PURGE_RETENTION_DAYS=30

# --- Signature des access tokens RS256 (TLX-020) ---
# Clé privée PEM (PKCS#8), sauts de ligne échappés en \n. Générer avec :
#   pnpm --filter @talent-x/api keys:generate
# REQUISE en staging/production (secret d'environnement, jamais commitée).
# En dev/test, si absente, une clé ÉPHÉMÈRE est générée au démarrage (jetons
# invalidés à chaque redémarrage). Voir src/auth/keys/README.md.
# JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Identifiant de clé (kid). Optionnel : dérivé du thumbprint RFC 7638 si absent.
# JWT_KEY_ID="..."

# Rotation : clés publiques retirées encore acceptées en vérification
# (JSON [{ "kid": "...", "publicKey": "-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----" }]).
# JWT_ADDITIONAL_PUBLIC_KEYS='[]'

# --- Durées de vie des jetons (TLX-021) — non secrètes, défauts sûrs ---
# Access token (court), en secondes. Défaut : 900 (15 min).
# ACCESS_TOKEN_TTL_SECONDS=900
# Refresh token, en secondes. Défaut : 2592000 (30 jours).
# REFRESH_TOKEN_TTL_SECONDS=2592000
# Émetteur (claim iss) des access tokens. Défaut : talent-x.
# JWT_ISSUER=talent-x

# --- Consentement RGPD (TLX-031) — non secret ---
# Version courante des textes de consentement, enregistrée avec chaque
# consentement quand le client ne précise pas la version présentée. À
# incrémenter quand un texte change (trace de la base juridique). Défaut : 2026-01.
# CONSENT_TEXT_VERSION=2026-01
