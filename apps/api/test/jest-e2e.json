{
  "preset": "ts-jest",
  "testEnvironment": "node",
  "rootDir": "..",
  "roots": ["<rootDir>/test"],
  "testRegex": "\\.e2e-spec\\.ts$",
  "moduleFileExtensions": ["ts", "js", "json"],
  "setupFiles": ["<rootDir>/test/setup-e2e.ts"],
  "transform": {
    "^.+\\.ts$": ["ts-jest", { "tsconfig": "<rootDir>/tsconfig.spec.json" }]
  }
}
